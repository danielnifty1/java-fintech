server:
  servlet:
    context-path: /api/v1

spring:
  web:
    error:
      include-binding-errors: always  # ← moved here
      include-message: always
  datasource:
    url: ${DB_URL}
    username: ${DB_USERNAME}
    password:
    driver-class-name: com.mysql.cj.jdbc.Driver
  devtools:
    restart:
      enabled: true
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true

jwt:
  secret: ${JWT_SECRET}
  expiration: ${JWT_EXPIRATION}

cloudinary:                               # ✅ top level, not under jwt
  cloud-name: ${CLOUDINARY_CLOUD_NAME}   # ✅ yml syntax, not .properties
  api-key: ${CLOUDINARY_API_KEY}
  api-secret: ${CLOUDINARY_API_SECRET}